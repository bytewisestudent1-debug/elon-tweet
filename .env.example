# ===========================================================================
# Elon Tweet — example environment variables
# ===========================================================================
# Copy this file to ".env" and fill in real values:
#
#     cp .env.example .env        (macOS/Linux)
#     copy .env.example .env      (Windows)
#
# The ".env" file is read automatically at startup by the "dotenv" package.
# NEVER commit your real .env — it can hold secrets.
# ===========================================================================

# Port the server listens on. Render sets this for you in production.
PORT=3000

# Postgres connection string: postgres://USER:PASSWORD@HOST:PORT/DATABASE
# Render gives you this value when you create a Postgres instance.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/elon_tweet

# Secret used to sign the login session cookie.
# Use a long random string in production (e.g. run: openssl rand -hex 32).
SESSION_SECRET=change-me-to-a-long-random-string
